<section class="featured-products">
  <h2 class="featured-products__title">Shop The Collection</h2>

  <div class="featured-products__grid">
    {% for product in section.settings.collection.products limit: 3 %}
      <a href="{{ product.url }}" class="featured-products__card">
        <div class="featured-products__image-wrapper">
          {% if product.featured_image %}
            <img
              src="{{ product.featured_image | img_url: '600x600', crop: 'center' }}"
              alt="{{ product.title }}"
              class="featured-products__image"
            >
          {% endif %}
        </div>
        <div class="featured-products__info">
          <h3 class="featured-products__name">{{ product.title }}</h3>
          <p class="featured-products__price">{{ product.price | money }}</p>
          <span class="featured-products__btn">Shop Now</span>
        </div>
      </a>
    {% endfor %}
  </div>
</section>

<style>
  .featured-products {
    background-color: #000;
    color: #fff;
    padding: 80px 40px;
    text-align: center;
  }

  .featured-products__title {
    font-size: 2.5rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 3px;
    margin-bottom: 50px;
    color: #fff;
  }

  .featured-products__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 30px;
    max-width: 1200px;
    margin: 0 auto;
  }

  .featured-products__card {
    text-decoration: none;
    color: #fff;
    background-color: #111;
    border: 1px solid #333;
    transition: border-color 0.3s ease, transform 0.3s ease;
  }

  .featured-products__card:hover {
    border-color: #fff;
    transform: translateY(-4px);
  }

  .featured-products__image-wrapper {
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
  }

  .featured-products__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
    filter: grayscale(100%);
  }

  .featured-products__card:hover .featured-products__image {
    transform: scale(1.05);
  }

  .featured-products__info {
    padding: 20px;
  }

  .featured-products__name {
    font-size: 1.1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: 10px;
  }

  .featured-products__price {
    font-size: 1rem;
    margin-bottom: 15px;
    color: #aaa;
  }

  .featured-products__btn {
    display: inline-block;
    border: 2px solid #fff;
    padding: 8px 24px;
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    transition: background-color 0.3s ease, color 0.3s ease;
  }

  .featured-products__card:hover .featured-products__btn {
    background-color: #fff;
    color: #000;
  }

  @media (max-width: 768px) {
    .featured-products__grid {
      grid-template-columns: 1fr;
    }
  }
</style>

{% schema %}
{
  "name": "Featured Products",
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    }
  ]
}
{% endschema %}