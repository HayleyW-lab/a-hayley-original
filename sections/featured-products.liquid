<section class="featured-products">
  <div class="featured-products__header">
    <h2 class="featured-products__title">{{ section.settings.title | default: 'Shop The Collection' }}</h2>
    {% if section.settings.collection != blank %}
      <a href="{{ section.settings.collection.url }}" class="featured-products__view-all">
        View All
      </a>
    {% endif %}
  </div>

  <div class="featured-products__grid">
    {% assign product_limit = section.settings.product_limit | default: 3 %}
    {% for product in section.settings.collection.products limit: product_limit %}
      <a href="{{ product.url }}" class="featured-products__card">

        <div class="featured-products__image-wrapper">
          {% if product.featured_image %}
            <img
              src="{{ product.featured_image | img_url: '600x600', crop: 'center' }}"
              alt="{{ product.featured_image.alt | default: product.title }}"
              class="featured-products__image"
              loading="lazy"
            >
          {% else %}
            <div class="featured-products__image-placeholder">
              {{ product.title | slice: 0 }}
            </div>
          {% endif %}
        </div>

        <div class="featured-products__info">
          <h3 class="featured-products__name">{{ product.title }}</h3>
          <p class="featured-products__price">
            {% if product.compare_at_price > product.price %}
              <span class="featured-products__price--original">{{ product.compare_at_price | money }}</span>
            {% endif %}
            {{ product.price | money }}
          </p>
          <span class="featured-products__btn">
            {% if product.available %}
              Shop Now
            {% else %}
              Sold Out
            {% endif %}
          </span>
        </div>

      </a>
    {% else %}
      <p class="featured-products__empty">No products found. Select a collection in the theme customiser.</p>
    {% endfor %}
  </div>
</section>

{% stylesheet %}
  .featured-products {
    background-color: #000;
    color: #fff;
    padding: 100px 40px;
  }

  .featured-products__header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    max-width: 1200px;
    margin: 0 auto 50px;
    flex-wrap: wrap;
    gap: 16px;
  }

  .featured-products__title {
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #fff;
    margin: 0;
    line-height: 1;
  }

  .featured-products__view-all {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.5);
    text-decoration: none;
    border-bottom: 1px solid rgba(255, 255, 255, 0.2);
    padding-bottom: 2px;
    transition: color 0.25s, border-color 0.25s;
    white-space: nowrap;
  }

  .featured-products__view-all:hover {
    color: #fff;
    border-color: #fff;
  }

  .featured-products__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
    max-width: 1200px;
    margin: 0 auto;
  }

  .featured-products__card {
    text-decoration: none;
    color: #fff;
    background-color: #111;
    border: 1px solid transparent;
    transition: border-color 0.3s ease, transform 0.3s ease;
    display: block;
  }

  .featured-products__card:hover {
    border-color: rgba(255, 255, 255, 0.4);
    transform: translateY(-4px);
  }

  .featured-products__image-wrapper {
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: #111;
  }

  .featured-products__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
    filter: grayscale(100%);
  }

  .featured-products__card:hover .featured-products__image {
    transform: scale(1.05);
  }

  .featured-products__image-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 4rem;
    font-weight: 900;
    color: rgba(255, 255, 255, 0.08);
    text-transform: uppercase;
    background: #111;
  }

  .featured-products__info {
    padding: 24px 20px 20px;
  }

  .featured-products__name {
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    margin-bottom: 10px;
    line-height: 1.3;
  }

  .featured-products__price {
    font-size: 0.9rem;
    margin-bottom: 16px;
    color: rgba(255, 255, 255, 0.5);
    display: flex;
    gap: 8px;
    align-items: center;
  }

  .featured-products__price--original {
    text-decoration: line-through;
    font-size: 0.8rem;
    opacity: 0.5;
  }

  .featured-products__btn {
    display: inline-block;
    border: 1px solid rgba(255, 255, 255, 0.3);
    padding: 8px 20px;
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    transition: background-color 0.25s ease, color 0.25s ease, border-color 0.25s;
  }

  .featured-products__card:hover .featured-products__btn {
    background-color: #fff;
    color: #000;
    border-color: #fff;
  }

  .featured-products__empty {
    color: rgba(255, 255, 255, 0.3);
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    grid-column: span 3;
    text-align: center;
    padding: 60px 0;
  }

  @media (max-width: 768px) {
    .featured-products {
      padding: 72px 20px;
    }

    .featured-products__grid {
      grid-template-columns: 1fr 1fr;
      gap: 2px;
    }

    .featured-products__empty {
      grid-column: span 2;
    }
  }

  @media (max-width: 480px) {
    .featured-products__grid {
      grid-template-columns: 1fr;
    }

    .featured-products__empty {
      grid-column: span 1;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Featured Products",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Shop The Collection"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "product_limit",
      "label": "Number of products",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 3
    }
  ],
  "presets": [
    {
      "name": "Featured Products"
    }
  ]
}
{% endschema %}
