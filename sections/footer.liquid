<footer class="site-footer">

  <div class="footer__top">

    <!-- Brand col -->
    <div class="footer__brand">
      {% if section.settings.logo %}
        <a href="{{ routes.root_url }}" class="footer__logo-link">
          <img
            src="{{ section.settings.logo | img_url: '240x' }}"
            alt="{{ shop.name }}"
            class="footer__logo-img"
          >
        </a>
      {% else %}
        <a href="{{ routes.root_url }}" class="footer__logo-text">
          {{ shop.name }}
        </a>
      {% endif %}

      {% if section.settings.tagline != blank %}
        <p class="footer__tagline">{{ section.settings.tagline }}</p>
      {% endif %}

      <!-- Social icons -->
      <div class="footer__socials">
        {% if section.settings.instagram_url != blank %}
          <a href="{{ section.settings.instagram_url }}" class="footer__social-link" aria-label="Instagram" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="0.5" fill="currentColor" stroke="none"/></svg>
          </a>
        {% endif %}
        {% if section.settings.tiktok_url != blank %}
          <a href="{{ section.settings.tiktok_url }}" class="footer__social-link" aria-label="TikTok" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.75a4.85 4.85 0 0 1-1.01-.06z"/></svg>
          </a>
        {% endif %}
        {% if section.settings.email != blank %}
          <a href="mailto:{{ section.settings.email }}" class="footer__social-link" aria-label="Email">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m2 7 10 7 10-7"/></svg>
          </a>
        {% endif %}
      </div>
    </div>

    <!-- Nav col -->
    <div class="footer__col">
      <h4 class="footer__col-heading">Shop</h4>
      {% for link in section.settings.menu.links %}
        <a href="{{ link.url }}" class="footer__col-link">{{ link.title }}</a>
      {% endfor %}
    </div>

    <!-- Help col -->
    <div class="footer__col">
      <h4 class="footer__col-heading">Help</h4>
      {% for link in section.settings.help_menu.links %}
        <a href="{{ link.url }}" class="footer__col-link">{{ link.title }}</a>
      {% endfor %}
    </div>

  </div>

  <!-- Bottom bar -->
  <div class="footer__bottom">
    <p class="footer__copyright">
      &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.
    </p>

    <div class="footer__payment">
      {% if section.settings.show_payment_icons %}
        {% for type in shop.enabled_payment_types %}
          {{ type | payment_type_svg_tag }}
        {% endfor %}
      {% endif %}
    </div>

    <p class="footer__made">
      Made in Australia &nbsp;·&nbsp; Fulfilled by Printful
    </p>
  </div>

</footer>

{% stylesheet %}
  .site-footer {
    background-color: #0f0f0f;
    color: #fff;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding: 80px 40px 40px;
  }

  /* ── Top grid ── */
  .footer__top {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 60px;
    max-width: 1200px;
    margin: 0 auto 60px;
  }

  /* ── Brand ── */
  .footer__logo-img {
    height: 2.8rem;
    width: auto;
    display: block;
    margin-bottom: 16px;
  }

  .footer__logo-text {
    font-size: 1.2rem;
    font-weight: 900;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #fff;
    text-decoration: none;
    display: block;
    margin-bottom: 16px;
  }

  .footer__tagline {
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.4);
    line-height: 1.7;
    max-width: 220px;
    margin-bottom: 24px;
    letter-spacing: 0.03em;
  }

  /* ── Socials ── */
  .footer__socials {
    display: flex;
    gap: 10px;
  }

  .footer__social-link {
    width: 36px;
    height: 36px;
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255, 255, 255, 0.5);
    text-decoration: none;
    transition: border-color 0.25s, color 0.25s, background 0.25s;
  }

  .footer__social-link:hover {
    border-color: rgba(255, 255, 255, 0.6);
    color: #fff;
    background: rgba(255, 255, 255, 0.05);
  }

  .footer__social-link svg {
    width: 14px;
    height: 14px;
  }

  /* ── Nav cols ── */
  .footer__col-heading {
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.35);
    margin-bottom: 20px;
  }

  .footer__col-link {
    display: block;
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.6);
    text-decoration: none;
    margin-bottom: 12px;
    transition: color 0.25s;
    letter-spacing: 0.02em;
  }

  .footer__col-link:hover {
    color: #fff;
  }

  /* ── Bottom bar ── */
  .footer__bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 16px;
    max-width: 1200px;
    margin: 0 auto;
    padding-top: 32px;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .footer__copyright,
  .footer__made {
    font-size: 0.7rem;
    color: rgba(255, 255, 255, 0.3);
    letter-spacing: 0.06em;
  }

  .footer__copyright a {
    color: inherit;
    text-decoration: none;
  }

  .footer__payment {
    display: flex;
    gap: 8px;
    align-items: center;
    flex-wrap: wrap;
  }

  .footer__payment svg {
    height: 20px;
    width: auto;
    opacity: 0.4;
    filter: grayscale(100%);
  }

  /* ── Mobile ── */
  @media (max-width: 768px) {
    .site-footer {
      padding: 60px 24px 32px;
    }

    .footer__top {
      grid-template-columns: 1fr 1fr;
      gap: 40px;
    }

    .footer__brand {
      grid-column: span 2;
    }

    .footer__bottom {
      flex-direction: column;
      align-items: flex-start;
      gap: 12px;
    }
  }

  @media (max-width: 480px) {
    .footer__top {
      grid-template-columns: 1fr;
    }

    .footer__brand {
      grid-column: span 1;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.footer",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Footer logo"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "Wearable statements. No grey areas."
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Shop menu"
    },
    {
      "type": "link_list",
      "id": "help_menu",
      "label": "Help menu"
    },
    {
      "type": "text",
      "id": "instagram_url",
      "label": "Instagram URL",
      "default": "https://www.instagram.com/ahayleyoriginal"
    },
    {
      "type": "text",
      "id": "tiktok_url",
      "label": "TikTok URL",
      "default": "https://www.tiktok.com/@ahayleyoriginal"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Contact email",
      "default": "designer@ahayleyoriginal.com"
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "t:labels.show_payment_icons",
      "default": true
    }
  ]
}
{% endschema %}
