<header class="site-header" role="banner">

  <div class="header__logo">
    {% if section.settings.logo %}
      <a href="{{ routes.root_url }}">
        <img
          src="{{ section.settings.logo | img_url: '300x' }}"
          alt="{{ shop.name }}"
          class="header__logo-img"
        >
      </a>
    {% else %}
      <a href="{{ routes.root_url }}" class="header__logo-text">
        {{ shop.name }}
      </a>
    {% endif %}
  </div>

  <nav class="header__menu" role="navigation" aria-label="Main menu">
    {% for link in section.settings.menu.links %}
      <a
        href="{{ link.url }}"
        class="header__nav-link{% if link.active %} header__nav-link--active{% endif %}"
      >
        {{ link.title }}
      </a>
    {% endfor %}
  </nav>

  <div class="header__icons">
    {% if shop.customer_accounts_enabled %}
      <shopify-account menu="{{ section.settings.customer_account_menu }}" class="header__icon-btn">
        {{ 'icon-account.svg' | inline_asset_content }}
      </shopify-account>
    {% endif %}

    <a href="{{ routes.cart_url }}" class="header__icon-btn header__cart" aria-label="Cart">
      {{ 'icon-cart.svg' | inline_asset_content }}
      {% if cart.item_count > 0 %}
        <span class="header__cart-count">{{ cart.item_count }}</span>
      {% endif %}
    </a>
  </div>

</header>

{% stylesheet %}
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    height: 5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 2.5rem;
    background-color: rgba(0, 0, 0, 0.92);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    transition: background-color 0.3s ease;
  }

  /* ── Logo ── */
  .header__logo-img {
    height: 3rem;
    width: auto;
    display: block;
  }

  .header__logo-text {
    font-family: 'Bebas Neue', 'Arial Black', sans-serif;
    font-size: 1.4rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-foreground, #f5f5f0);
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .header__logo-text:hover {
    opacity: 0.7;
  }

  /* ── Nav ── */
  .header__menu {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .header__nav-link {
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(245, 245, 240, 0.55);
    text-decoration: none;
    transition: color 0.25s ease;
    position: relative;
  }

  .header__nav-link::after {
    content: '';
    position: absolute;
    bottom: -3px;
    left: 0;
    width: 0;
    height: 1px;
    background: var(--color-foreground, #f5f5f0);
    transition: width 0.3s ease;
  }

  .header__nav-link:hover,
  .header__nav-link--active {
    color: #f5f5f0;
  }

  .header__nav-link:hover::after,
  .header__nav-link--active::after {
    width: 100%;
  }

  /* ── Icons ── */
  .header__icons {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .header__icon-btn {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 50%;
    color: var(--color-foreground, #f5f5f0);
    text-decoration: none;
    transition: border-color 0.25s, background 0.25s;
  }

  .header__icon-btn:hover {
    border-color: rgba(255, 255, 255, 0.6);
    background: rgba(255, 255, 255, 0.06);
  }

  .header__icon-btn svg {
    width: 1.1rem;
    height: 1.1rem;
  }

  /* Cart count badge */
  .header__cart-count {
    position: absolute;
    top: -4px;
    right: -4px;
    min-width: 16px;
    height: 16px;
    padding: 0 3px;
    background: #f5f5f0;
    color: #0a0a0a;
    font-size: 0.55rem;
    font-weight: 700;
    letter-spacing: 0;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
  }

  /* ── Mobile ── */
  @media (max-width: 768px) {
    .site-header {
      padding: 0 1.25rem;
    }

    .header__menu {
      display: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:labels.menu"
    },
    {
      "type": "link_list",
      "id": "customer_account_menu",
      "label": "t:labels.customer_account_menu",
      "default": "customer-account-main-menu"
    }
  ]
}
{% endschema %}

